#!/bin/bash

# Configuration Variables - EDIT THESE
REGION="<YOUR_AZURE_REGION>"
RESOURCE_GROUP="<YOUR_RESOURCE_GROUP>"
SUBSCRIPTION_ID="<YOUR_SUBSCRIPTION_ID>"
MACHINE_NAME="<YOUR_SWITCH_HOSTNAME>"
TENANT_ID="<YOUR_TENANT_ID>"
# DNS_SERVER_1="<DNS_SERVER_1>" (Uncomment and set ONLY if custom DNS servers are needed ex: 10.10.240.23)
# DNS_SERVER_2="<DNS_SERVER_2>" (Uncomment and set ONLY if custom DNS servers are needed ex: 10.10.240.24)

# Configuration Variables - EDIT THESE
WORKSPACE_ID="<LOG_ANALYTICS_WORKSPACE_ID>"
PRIMARY_KEY="<LOG_ANALYTICS_PRIMARY_KEY>"
SECONDARY_KEY="<LOG_ANALYTICS_SECONDARY_KEY>"
GNMI_USER="<NX-OS_USERNAME>"
GNMI_PASS="<NX-OS_PASSWORD>"
COLLECTOR_URL="https://github.com/microsoft/arc-switch/releases/download/gnmi-1.2603.1/gnmi-collector-1.2603.1-linux-amd64.tar.gz"
GNMI_INSTALL_DIR="/opt/gnmi-collector"
AZCMAGENT_RPM_URL="https://github.com/microsoft/arc-switch/releases/download/v0.0.2-alpha-rpm/azcmagent-1.54.03131-2112.x86_64.rpm"

cd /opt
curl -sSL "$AZCMAGENT_RPM_URL" -o azcmagent.rpm
if [ $? -eq 0 ]; then
    rpm -Uvh --nopost azcmagent.rpm 2>/dev/null
    # NX-OS installs RPM contents to /bootflash/rpm_test/ instead of /.
    # Relocate to the expected paths if needed.
    if [ -d /bootflash/rpm_test/opt/azcmagent ] && [ ! -f /opt/azcmagent/bin/azcmagent ]; then
        echo "Relocating RPM contents from /bootflash/rpm_test/ ..."
        cp -r /bootflash/rpm_test/opt/azcmagent /opt/azcmagent
        cp -r /bootflash/rpm_test/opt/GC_Ext /opt/GC_Ext 2>/dev/null
        cp -r /bootflash/rpm_test/opt/GC_Service /opt/GC_Service 2>/dev/null
        cp -r /bootflash/rpm_test/var/opt/azcmagent /var/opt/azcmagent 2>/dev/null
    fi
    # Ensure all required azcmagent subdirectories exist (RPM relocation may miss empty dirs)
    mkdir -p /var/opt/azcmagent/{certs,log,tokens,socks,arcproxy}
    chmod 700 /var/opt/azcmagent/certs /var/opt/azcmagent/tokens
    ln -sf /opt/azcmagent/bin/azcmagent /usr/bin/azcmagent
    rm -f azcmagent.rpm
fi

# PART 1: DNS AND GC CONFIG SETUP
cat > /opt/GC_Service/GC/gc.config <<'EOF'
{
    "ServiceType": "GCArc"
}
EOF

cat > /opt/GC_Ext/GC/gc.config <<'EOF'
{
    "ServiceType": "Extension"
}
EOF

