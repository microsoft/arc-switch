echo "--- Installing gNMI Telemetry Collector ---"

mkdir -p "$GNMI_INSTALL_DIR"

# If collector binary already exists, skip download
if [ -x "$GNMI_INSTALL_DIR/gnmi-collector" ]; then
    echo "gNMI collector already installed at ${GNMI_INSTALL_DIR}/gnmi-collector — skipping download"
    "$GNMI_INSTALL_DIR/gnmi-collector" --version 2>/dev/null
else
    GNMI_TEMP_DIR="/tmp/gnmi-collector-install"
    mkdir -p "$GNMI_TEMP_DIR"
    cd "$GNMI_TEMP_DIR" || exit 1

    echo "Downloading gNMI collector from ${COLLECTOR_URL} ..."
    curl -sSL -f "$COLLECTOR_URL" -o gnmi-collector.tar.gz
    if [ $? -ne 0 ]; then
        echo "WARNING: Failed to download gNMI collector from ${COLLECTOR_URL}"
        echo "         You can manually upload the binary to ${GNMI_INSTALL_DIR}/gnmi-collector later."
    else
        tar -xzf gnmi-collector.tar.gz
        if [ $? -ne 0 ]; then
            echo "WARNING: Failed to extract gNMI collector archive"
        else
            cp gnmi-collector "$GNMI_INSTALL_DIR/gnmi-collector"
            chmod +x "$GNMI_INSTALL_DIR/gnmi-collector"
            if [ ! -f "$GNMI_INSTALL_DIR/config.yaml" ]; then
                cp config.cisco.yaml "$GNMI_INSTALL_DIR/config.yaml" 2>/dev/null
                echo "Installed default config.yaml"
            else
                echo "Existing config.yaml preserved (not overwritten)"
            fi
            echo "gNMI collector installed to ${GNMI_INSTALL_DIR}"
            "$GNMI_INSTALL_DIR/gnmi-collector" --version 2>/dev/null
        fi
    fi
    rm -rf "$GNMI_TEMP_DIR"
fi

find /opt/azcmagent -name "*.sh" -type f -exec chmod +x {} \; 2>/dev/null
find /var/tmp -name "rpm-tmp.*" -type f -exec chmod +x {} \; 2>/dev/null

# PART 9: CREATE gNMI COLLECTOR CREDENTIALS FILE

cat > "${GNMI_INSTALL_DIR}/env" << GNMIENV_EOF
# gNMI Collector credentials
# This file is sourced by the init.d service script.
export GNMI_USER="${GNMI_USER}"
export GNMI_PASS="${GNMI_PASS}"
export WORKSPACE_ID="${WORKSPACE_ID}"
export PRIMARY_KEY="${PRIMARY_KEY}"
export SECONDARY_KEY="${SECONDARY_KEY}"
GNMIENV_EOF

chmod 600 "${GNMI_INSTALL_DIR}/env"
echo "Credentials file created at ${GNMI_INSTALL_DIR}/env (permissions: 600)"

# PART 10: CREATE gNMI COLLECTOR INIT.D SERVICE

cat > /etc/init.d/gnmi-collectord << 'GNMI_INITD_EOF'
#!/bin/bash
# /etc/init.d/gnmi-collectord
#
# init.d service script for the gNMI telemetry collector daemon.
# Manages the gnmi-collector process running in poll mode (periodic gNMI Get).
#
# Usage: /etc/init.d/gnmi-collectord {start|stop|restart|status}

DAEMON_NAME="gnmi-collector"
INSTALL_DIR="/opt/gnmi-collector"
DAEMON_PATH="${INSTALL_DIR}/gnmi-collector"
CONFIG_PATH="${INSTALL_DIR}/config.yaml"
ENV_FILE="${INSTALL_DIR}/env"
PIDFILE="/var/run/gnmi-collector.pid"
LOGFILE="/var/log/gnmi-collector.log"
MAX_LOG_SIZE=10485760  # 10 MB

if [ ! -x "$DAEMON_PATH" ]; then
    echo "ERROR: ${DAEMON_NAME} binary not found at ${DAEMON_PATH}"
    exit 1
fi

if [ ! -f "$CONFIG_PATH" ]; then
    echo "ERROR: config file not found at ${CONFIG_PATH}"
    exit 1
fi

rotate_log() {
    if [ -f "$LOGFILE" ]; then
        local size
        size=$(stat -f%z "$LOGFILE" 2>/dev/null || stat -c%s "$LOGFILE" 2>/dev/null)
        if [ "$size" -gt "$MAX_LOG_SIZE" ] 2>/dev/null; then
            mv "$LOGFILE" "${LOGFILE}.old"
        fi
    fi
}

start() {
    if [ -f "$PIDFILE" ] && ps -p "$(cat "$PIDFILE")" > /dev/null 2>&1; then
        echo "${DAEMON_NAME} is already running (PID $(cat "$PIDFILE"))"
        return 0
    fi

    rm -f "$PIDFILE"
    pkill -f "${DAEMON_PATH}" 2>/dev/null
    sleep 1

    mkdir -p "$(dirname "$LOGFILE")"
    rotate_log

    [ -f /etc/environment ] && source /etc/environment
    [ -f "$ENV_FILE" ] && source "$ENV_FILE"

    if [ -z "$GNMI_USER" ] || [ -z "$GNMI_PASS" ]; then
        echo "ERROR: GNMI_USER and GNMI_PASS must be set in ${ENV_FILE} or /etc/environment"
        return 1
    fi
    if [ -z "$WORKSPACE_ID" ] || [ -z "$PRIMARY_KEY" ]; then
        echo "ERROR: WORKSPACE_ID and PRIMARY_KEY must be set in ${ENV_FILE} or /etc/environment"
        return 1
    fi

    echo "Starting ${DAEMON_NAME}..." >> "$LOGFILE"

    nohup "$DAEMON_PATH" --config "$CONFIG_PATH" >> "$LOGFILE" 2>&1 &
    PID=$!
    echo $PID > "$PIDFILE"

    sleep 3
    if ps -p $PID > /dev/null 2>&1; then
        echo "${DAEMON_NAME} started (PID ${PID})"
        return 0
    else
        echo "ERROR: ${DAEMON_NAME} failed to start. Check ${LOGFILE}"
        rm -f "$PIDFILE"
        return 1
    fi
}

stop() {
    if [ ! -f "$PIDFILE" ]; then
        echo "${DAEMON_NAME} is not running (no PID file)"
        return 0
    fi

    local PID
    PID=$(cat "$PIDFILE")

    if ! ps -p "$PID" > /dev/null 2>&1; then
        echo "${DAEMON_NAME} is not running (stale PID file)"
        rm -f "$PIDFILE"
        return 0
    fi

    echo "Stopping ${DAEMON_NAME} (PID ${PID})..."
    kill "$PID" 2>/dev/null

    for i in $(seq 1 15); do
        if ! ps -p "$PID" > /dev/null 2>&1; then
            echo "${DAEMON_NAME} stopped"
            rm -f "$PIDFILE"
            return 0
        fi
        sleep 1
    done

    echo "WARNING: ${DAEMON_NAME} did not stop gracefully, forcing..."
    kill -9 "$PID" 2>/dev/null
    rm -f "$PIDFILE"
    echo "${DAEMON_NAME} killed"
}

status() {
    if [ -f "$PIDFILE" ] && ps -p "$(cat "$PIDFILE")" > /dev/null 2>&1; then
        echo "${DAEMON_NAME} is running (PID $(cat "$PIDFILE"))"
        return 0
    else
        echo "${DAEMON_NAME} is stopped"
        return 3
    fi
}

case "$1" in
    start)   start ;;
    stop)    stop ;;
    restart) stop; sleep 2; start ;;
    status)  status ;;
    *)       echo "Usage: $0 {start|stop|restart|status}"; exit 1 ;;
esac
GNMI_INITD_EOF

chmod +x /etc/init.d/gnmi-collectord
echo "init.d service installed at /etc/init.d/gnmi-collectord"

# PART 11: VALIDATE gNMI CONNECTIVITY AND START COLLECTOR

echo ""
echo "--- Validating gNMI connectivity ---"

source "${GNMI_INSTALL_DIR}/env"

echo "Running dry-run connectivity test..."
"$GNMI_INSTALL_DIR/gnmi-collector" --config "$GNMI_INSTALL_DIR/config.yaml" --once --dry-run > /tmp/gnmi-test-output.txt 2>&1
TEST_RESULT=$?

if [ $TEST_RESULT -eq 0 ]; then
    echo "gNMI connectivity test PASSED"
    LINES=$(wc -l < /tmp/gnmi-test-output.txt)
    echo "  Collected ${LINES} lines of output"
else
    echo "WARNING: gNMI connectivity test failed (exit code ${TEST_RESULT})"
    echo "  Check /tmp/gnmi-test-output.txt for details"
    echo "  Common causes:"
    echo "    - gRPC feature not enabled: run 'feature grpc' in NX-OS config"
    echo "    - VRF not configured: run 'grpc use-vrf default' in NX-OS config"
    echo "    - Invalid GNMI_USER / GNMI_PASS credentials"
    echo "    - gNMI server not listening on localhost:50051"
fi

rm -f /tmp/gnmi-test-output.txt

echo ""
echo "Starting gNMI collector service..."
/etc/init.d/gnmi-collectord start
sleep 2
/etc/init.d/gnmi-collectord status

# PART 12: CREATE PERSISTENT AUTOSTART SCRIPT IN RPMSTORE

echo "Configuring Persistent Boot Auto-Start..."

mkdir -p /bootflash/.rpmstore/config/etc/rc3.d

cat > /bootflash/.rpmstore/config/etc/init.d/arcnet-autostart << 'AUTOSTART_EOF'
#!/bin/bash

case "$1" in
    start)
        (
            sleep 120
            if [ ! -f /tmp/arcnet-boot-complete ]; then
                touch /tmp/arcnet-boot-complete
                echo "=== arcnet-autostart triggered at $(date) ===" >> /bootflash/arcnet-debug.log
                /bin/bash /bootflash/arcnet-setup.sh >> /bootflash/arcnet-debug.log 2>&1
                echo "=== arcnet-setup finished with code $? at $(date) ===" >> /bootflash/arcnet-debug.log
            fi
        ) &
        ;;
    stop)
        ;;
    *)
        echo "Usage: $0 {start|stop}"
        exit 1
        ;;
esac
exit 0
AUTOSTART_EOF

chmod +x /bootflash/.rpmstore/config/etc/init.d/arcnet-autostart

# Create symlink in persistent rc3.d
ln -sf ../init.d/arcnet-autostart /bootflash/.rpmstore/config/etc/rc3.d/S99arcnet-autostart
rm -f /bootflash/arcnet-debug.log 2>/dev/null

echo "Persistent boot auto-start configured."

echo ""
echo "============================================================================"
echo "Azure Arc + gNMI Telemetry Setup Complete!"
echo "============================================================================"
echo ""
echo "NEXT STEPS:"
echo "1. Connect the Arc agent to Azure (see README.md for instructions)"
echo "2. Verify Arc agent connection with: azcmagent show"
echo "3. Check Arc service status with: /etc/init.d/himdsd status"
echo "4. View Arc logs in /var/log/arc/"
echo ""
echo "gNMI TELEMETRY COLLECTOR:"
echo "  Binary:      ${GNMI_INSTALL_DIR}/gnmi-collector"
echo "  Config:      ${GNMI_INSTALL_DIR}/config.yaml"
echo "  Credentials: ${GNMI_INSTALL_DIR}/env"
echo "  Service:     /etc/init.d/gnmi-collectord"
echo "  Logs:        /var/log/gnmi-collector.log"
echo ""
echo "Service management:"
echo "  /etc/init.d/gnmi-collectord status    Check if running"
echo "  /etc/init.d/gnmi-collectord restart   Restart the collector"
echo "  /etc/init.d/gnmi-collectord stop      Stop the collector"
echo ""
echo "Manual testing:"
echo "  ${GNMI_INSTALL_DIR}/gnmi-collector --config ${GNMI_INSTALL_DIR}/config.yaml --once --dry-run"
echo ""
echo "============================================================================"
