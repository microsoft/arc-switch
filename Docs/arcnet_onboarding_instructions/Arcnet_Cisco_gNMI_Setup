echo "Stopping services..."
for service in gcad extd arcproxyd himdsd; do
    /etc/init.d/$service stop 2>/dev/null
done

sleep 5
pkill -9 -f "gc_linux_service" 2>/dev/null
pkill -9 -f "arcproxy" 2>/dev/null
